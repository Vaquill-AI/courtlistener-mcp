# --- AUTH MODE -------------------------------------------------------------
# Two ways to authenticate against the CourtListener API:
#
# 1) Bring-your-own-key (BYOK, preferred for hosted / shared deployments):
#    Clients send their CourtListener token in every MCP request via either
#    'X-CourtListener-Token: <key>' or 'Authorization: Token <key>'.
#    No server-side env var needed.
#
# 2) Single-tenant fallback (self-hosted only):
#    Set COURT_LISTENER_API_KEY below. Used when no per-request header is
#    supplied. Leave UNSET in shared/public deployments to force BYOK.
#
# Get a free key: https://www.courtlistener.com/api/

COURT_LISTENER_API_KEY=

# --- SERVER ----------------------------------------------------------------
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4/
COURTLISTENER_TIMEOUT=30
COURTLISTENER_LOG_LEVEL=INFO

# Transport: stdio (CLI clients) | http (network) | sse (legacy)
MCP_TRANSPORT=http
MCP_PORT=8000
HOST=0.0.0.0
